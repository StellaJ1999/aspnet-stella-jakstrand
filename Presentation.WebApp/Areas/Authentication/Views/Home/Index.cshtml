@{
    ViewData["Title"] = "Sign Up";
}

@model SignUpForm

<section class="_auth">
    <div>
        <h1 class="title"> Become a Member</h1>
        <p class="description"> Sign up to continue your fitness journey. </p>
    </div>

    <hr />

    <form method="post" asp-area="Authentification" asp-controller="Home" asp-action="Index" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label" asp-for="Email"></label>
            <input class="form-input" asp-for="Email" />
            <span asp-validation-for="Email" class="field-validation"></span>
        </div>
    </form>

    <button class="btn" type="submit"> Continue </button>

    <div data-type="terms" class="form-group form-checkbox-group">
        <input class="form-input" asp-for="TermsAndConditions" />
        <label class="form-label" asp-for="TermsAndConditions"> I agree to the <a href="/terms-and-conditions">Terms and Conditions</a> </label>
        <span asp-validation-for="TermsAndConditions" class="field-validation"></span>
    </div>

    <div class="form-errormessage">
        <span class="field-validation-error" asp-validation-for="ErrorMessage"></span>
    </div>

</section>