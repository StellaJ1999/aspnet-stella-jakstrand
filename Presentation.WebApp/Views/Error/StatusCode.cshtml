@model int
@{
    ViewData["Title"] = Model.ToString();
}

<section class="error-page">
    <div class="container error-page__container">
        <h1 class="error-page__title">Error @Model</h1>
        <p class="error-page__description">Something went wrong while loading this page.</p>

        <a class="btn accent error-page__cta" asp-controller="Home" asp-action="Index">
            Back to Homepage
        </a>
    </div>
</section>